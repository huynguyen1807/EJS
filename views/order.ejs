<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Product Orders</title>

  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <div class="page-wrapper">
    <div class="container large">
      <h1>Product Orders</h1>

      <% if (message) { %>
        <div class="alert success">
          <%= message %>
        </div>
      <% } %>

      <table>
        <thead>
          <tr>
            <th>Customer Name</th>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Order Date</th>
            <th>Total Price</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if (orders.length > 0) { %>
            <% orders.forEach(function(order) { %>
              <tr>
                <td><%= order.customerName %></td>
                <td><%= order.productName %></td>
                <td><%= order.quantity %></td>

                <td>
                  <%= new Date(order.orderDate).toLocaleDateString("en-US") %>
                </td>

                <td>
                  <%= Number(order.totalPrice).toLocaleString("vi-VN") %> VND
                </td>

                <td>
                  <div class="action-group">
                    <a href="/orders/<%= order._id %>/edit" class="btn btn-update">
                      Update
                    </a>

                    <form
                      action="/orders/<%= order._id %>?_method=DELETE"
                      method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this order?')"
                    >
                      <button type="submit" class="btn btn-delete">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty">
                No orders found
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>

      <div class="center">
        <a href="/create-order" class="btn btn-primary btn-create">
          Create New Order
        </a>
      </div>
    </div>
  </div>
</body>
</html>